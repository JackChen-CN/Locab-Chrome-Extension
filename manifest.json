{
  "manifest_version": 3,
  "name": "Locab",
  "description": "Location + Vocabulary - Mark and review vocabulary words with context and positioning",
  "version": "1.0.0",
  "permissions": [
    "contextMenus",
    "activeTab",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Locab - Vocabulary Manager"
  },
  "options_page": "settings.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [{
    "resources": ["lib/compromise.min.js"],
    "matches": ["<all_urls>"]
  }]
}